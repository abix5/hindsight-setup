# Hindsight configuration template
# Copy this file to .env and replace placeholder values.

# --- Database ---
HINDSIGHT_API_DATABASE_URL=postgresql://hindsight:<db_password>@localhost:5432/hindsight_db
HINDSIGHT_API_STORE_TYPE=postgres
HINDSIGHT_API_DB_POOL_MIN_SIZE=5
HINDSIGHT_API_DB_POOL_MAX_SIZE=24

# --- LLM provider ---
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
HINDSIGHT_API_LLM_API_KEY=<your_api_key>
HINDSIGHT_API_LLM_MODEL=gpt-5.3-codex
HINDSIGHT_API_LLM_MAX_CONCURRENT=8
HINDSIGHT_API_LLM_TIMEOUT=180

# --- Per-operation LLM models ---
HINDSIGHT_API_RETAIN_LLM_MODEL=gpt-5.3-codex
HINDSIGHT_API_RETAIN_LLM_MAX_CONCURRENT=3

HINDSIGHT_API_REFLECT_LLM_MODEL=gpt-5.1-codex-mini
HINDSIGHT_API_REFLECT_LLM_MAX_CONCURRENT=8

HINDSIGHT_API_CONSOLIDATION_LLM_MODEL=gpt-5.1-codex-mini
HINDSIGHT_API_CONSOLIDATION_LLM_MAX_CONCURRENT=2

# --- Embeddings ---
HINDSIGHT_API_EMBEDDINGS_PROVIDER=local
HINDSIGHT_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-m3
HINDSIGHT_API_EMBEDDINGS_LOCAL_FORCE_CPU=false

# --- Reranker ---
HINDSIGHT_API_RERANKER_PROVIDER=local
HINDSIGHT_API_RERANKER_LOCAL_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
HINDSIGHT_API_RERANKER_LOCAL_FORCE_CPU=false
HINDSIGHT_API_RERANKER_LOCAL_MAX_CONCURRENT=2
HINDSIGHT_API_RERANKER_MAX_CANDIDATES=300

# --- Retrieval ---
HINDSIGHT_API_GRAPH_RETRIEVER=link_expansion
HINDSIGHT_API_RECALL_MAX_CONCURRENT=6
HINDSIGHT_API_RECALL_CONNECTION_BUDGET=2

# --- Retain pipeline ---
HINDSIGHT_API_RETAIN_MAX_COMPLETION_TOKENS=64000
HINDSIGHT_API_RETAIN_CHUNK_SIZE=3000
HINDSIGHT_API_RETAIN_EXTRACTION_MODE=concise

# --- Background workers ---
HINDSIGHT_API_WORKERS=1
HINDSIGHT_API_WORKER_MAX_SLOTS=2
HINDSIGHT_API_WORKER_CONSOLIDATION_MAX_SLOTS=1

# --- Performance ---
HINDSIGHT_API_LAZY_RERANKER=true
HINDSIGHT_API_SKIP_LLM_VERIFICATION=true

# --- Server ---
HINDSIGHT_API_LOG_LEVEL=info
HINDSIGHT_API_MCP_ENABLED=true

# --- HuggingFace cache paths ---
HF_HOME=./huggingface
HUGGINGFACE_HUB_CACHE=./huggingface/hub
SENTENCE_TRANSFORMERS_HOME=./huggingface/hub
